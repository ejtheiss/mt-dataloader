# Modern Treasury Dataloader — Environment Configuration
# Copy to .env and fill in your values.

DATALOADER_MT_API_KEY=sk_test_...
DATALOADER_MT_ORG_ID=org_...
DATALOADER_RUNS_DIR=runs
DATALOADER_LOG_LEVEL=INFO
DATALOADER_STAMP_LOADER_METADATA=false
DATALOADER_MAX_CONCURRENT_REQUESTS=5

# Webhook signature verification (optional).
# Copy the signing secret from MT Dashboard → Developers → Webhooks → your endpoint.
# Leave blank to skip verification (fine for sandbox/demos).
DATALOADER_WEBHOOK_SECRET=
