    "--mt-blue-500": "ref:--blue-500",  "--mt-blue-700": "ref:--blue-700",
    "--mt-green-50":  "ref:--green-50", "--mt-green-100": "ref:--green-100",
    "--mt-green-500": "ref:--green-500","--mt-green-700": "ref:--green-700",
    "--mt-red-50":  "ref:--red-50",     "--mt-red-100": "ref:--red-100",
    "--mt-red-500": "ref:--red-500",    "--mt-red-700": "ref:--red-700",
    "--mt-yellow-50":  "ref:--yellow-50","--mt-yellow-100": "ref:--yellow-100",
    "--mt-yellow-300": "ref:--yellow-300","--mt-yellow-700": "ref:--yellow-700",
    "--mt-orange-50": "ref:--orange-50","--mt-orange-100": "ref:--orange-100",
