  "bridges": {
    "--bg":              { "light": "ref:--app-background",      "dark": "mt.off-black" },
    "--surface":         { "light": "ref:--background-default",  "dark": "mt.off-black" },
    "--border":          { "light": "ref:--border-default",      "dark": "mt.gray-3" },
    "--text":            { "light": "ref:--text-default",         "dark": "mt.off-white" },
    "--primary":         { "light": "ref:--action-primary",       "dark": "mt.green-3" },
    "--primary-hover":   { "light": "ref:--action-primary-hover", "dark": "mt.green-4" },
    "--danger":          { "light": "ref:--action-critical",      "dark": "mt.orange-2" },
