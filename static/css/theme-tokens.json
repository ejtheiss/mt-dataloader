  "alpha": {
    "--alpha-black-50":    { "light": "rgba(0, 0, 0, 0.05)",       "dark": "rgba(255, 255, 255, 0.05)" },
    "--alpha-black-100":   { "light": "rgba(0, 0, 0, 0.12)",       "dark": "rgba(255, 255, 255, 0.12)" },
    "--alpha-black-200":   { "light": "rgba(0, 0, 0, 0.20)",       "dark": "rgba(255, 255, 255, 0.20)" },
    "--alpha-black-300":   { "light": "rgba(0, 0, 0, 0.30)",       "dark": "rgba(255, 255, 255, 0.30)" },
    "--shadow-select-bar": { "light": "0 1px 0px 0 rgba(0, 0, 0, 0.05)", "dark": "0 1px 0 0 rgba(255, 255, 255, 0.05)" },
    "--shadow-popover":    { "light": "0px 2px 10px 0px rgba(0, 0, 0, 0.1)", "dark": "0px 2px 10px 0px rgba(0, 0, 0, 0.4)" }
  },

  "semantics": {
    "--app-background":              { "light": "base.app-background",    "dark": "mt.off-black" },
    "--background-default":          { "light": "base.white",             "dark": "mt.gray-4" },
    "--background-light":            { "light": "mint.gray-25",           "dark": "mt.gray-4" },
    "--background-dark":             { "light": "mint.gray-800",          "dark": "mt.black" },

    "--button-background-default":         { "light": "base.white",       "dark": "mt.gray-4" },
    "--button-background-default-hover":   { "light": "mint.gray-25",     "dark": "mt.gray-3" },
    "--button-background-default-pressed": { "light": "mint.gray-50",     "dark": "mt.gray-2" },
    "--button-background-primary":         { "light": "mint.blue-500",    "dark": "mt.blue-2" },
    "--button-background-primary-hover":   { "light": "mint.blue-600",    "dark": "mt.blue-3" },
    "--button-background-primary-pressed": { "light": "mint.blue-700",    "dark": "mt.blue-4" },
    "--button-background-disabled":        { "light": "mint.blue-25",     "dark": "mt.gray-4" },

    "--surface-info":                { "light": "mint.yellow-25",         "dark": "mt.gold-4" },
    "--surface-critical":            { "light": "mint.red-25",            "dark": "mt.orange-4" },
    "--surface-success":             { "light": "mint.green-25",          "dark": "mt.green-4" },

    "--border-default":              { "light": "mint.gray-100",          "dark": "mt.gray-3" },
    "--border-muted":                { "light": "mint.gray-50",           "dark": "mt.gray-4" },
    "--border-strong":               { "light": "mint.gray-200",          "dark": "mt.gray-2" },

    "--text-default":                { "light": "mint.gray-800",          "dark": "mt.off-white" },
    "--text-hover":                  { "light": "mint.gray-500",          "dark": "mt.gray-2" },
    "--text-muted":                  { "light": "mint.gray-600",          "dark": "mt.gray-2" },
    "--text-disabled":               { "light": "mint.gray-700",          "dark": "mt.gray-3" },
    "--text-critical":               { "light": "mint.red-500",           "dark": "mt.orange-2" },
    "--text-success":                { "light": "mint.green-500",         "dark": "mt.green-2" },
    "--text-info":                   { "light": "mint.orange-500",        "dark": "mt.blue-2" },
    "--text-on-primary":             { "light": "base.white",             "dark": "mt.white" },
    "--text-on-critical":            { "light": "base.white",             "dark": "mt.white" },

    "--icon-default":                { "light": "mint.gray-700",          "dark": "mt.gray-2" },
    "--icon-strong":                 { "light": "mint.gray-900",          "dark": "mt.off-white" },
    "--icon-muted":                  { "light": "mint.gray-700",          "dark": "mt.gray-3" },
    "--icon-disabled":               { "light": "mint.gray-500",          "dark": "mt.gray-3" },
    "--icon-critical":               { "light": "mint.red-500",           "dark": "mt.orange-2" },
    "--icon-success":                { "light": "mint.green-500",         "dark": "mt.green-2" },
    "--icon-info":                   { "light": "mint.orange-500",        "dark": "mt.blue-2" },
    "--icon-on-primary":             { "light": "base.white",             "dark": "mt.white" },
    "--icon-on-critical":            { "light": "base.white",             "dark": "mt.white" },

    "--action-primary":              { "light": "mint.green-500",         "dark": "mt.green-3" },
    "--action-primary-hover":        { "light": "mint.green-600",         "dark": "mt.green-4" },
    "--action-primary-pressed":      { "light": "mint.green-700",         "dark": "mt.dark-green" },
    "--action-primary-disabled":     { "light": "mint.green-25",          "dark": "mt.green-4" },
    "--action-critical":             { "light": "mint.red-500",           "dark": "mt.orange-2" },
    "--action-critical-hover":       { "light": "mint.red-600",           "dark": "mt.orange-3" },
    "--action-critical-pressed":     { "light": "mint.red-700",           "dark": "mt.orange-4" },
    "--action-critical-disabled":    { "light": "mint.red-25",            "dark": "mt.orange-4" },
    "--action-default":              { "light": "base.white",             "dark": "mt.gray-4" },
    "--action-default-hover":        { "light": "mint.gray-50",           "dark": "mt.gray-3" },
    "--action-default-pressed":      { "light": "mint.gray-100",          "dark": "mt.gray-2" },
    "--action-default-disabled":     { "light": "mint.gray-25",           "dark": "mt.gray-4" },

    "--primary-interactive":         { "light": "mint.blue-500",          "dark": "mt.blue-2" },
    "--primary-interactive-hover":   { "light": "mint.blue-600",          "dark": "mt.blue-3" },
    "--primary-interactive-pressed": { "light": "mint.blue-700",          "dark": "mt.blue-4" },

    "--text-breadcrumb":             { "light": "ref:--text-muted",       "dark": "mt.gray-2" },
    "--text-breadcrumb-current":     { "light": "ref:--text-default",     "dark": "mt.off-white" },
    "--text-breadcrumb-separator":   { "light": "mint.gray-400",          "dark": "mt.gray-3" },
    "--text-page-subtitle":          { "light": "ref:--text-muted",       "dark": "mt.gray-2" },
    "--text-empty-state-icon":       { "light": "mint.gray-400",          "dark": "mt.gray-3" }
  },

  "badges": {
    "neutral":  { "bg": { "light": "mint.gray-50",     "dark": "mt.gray-4" },    "text": { "light": "mint.gray-700",    "dark": "mt.gray-1" } },
    "success":  { "bg": { "light": "mint.green-100",   "dark": "mt.green-4" },   "text": { "light": "mint.green-800",   "dark": "mt.green-1" } },
    "critical": { "bg": { "light": "mint.red-100",     "dark": "mt.orange-4" },  "text": { "light": "mint.red-800",     "dark": "mt.orange-1" } },
    "warning":  { "bg": { "light": "mint.yellow-100",  "dark": "mt.gold-4" },    "text": { "light": "mint.yellow-800",  "dark": "mt.gold-1" } },
    "warm":     { "bg": { "light": "mint.orange-100",  "dark": "mt.orange-4" },  "text": { "light": "mint.orange-800",  "dark": "mt.orange-1" } },
    "cool":     { "bg": { "light": "mint.blue-100",    "dark": "mt.blue-4" },    "text": { "light": "mint.blue-800",    "dark": "mt.blue-1" } },
    "info":     { "bg": { "light": "mint.violet-100",  "dark": "mt.violet-4" },  "text": { "light": "mint.violet-700",  "dark": "mt.violet-1" } },
    "purple":   { "bg": { "light": "mint.purple-100",  "dark": "mt.purple-4" },  "text": { "light": "mint.purple-800",  "dark": "mt.purple-1" } }
