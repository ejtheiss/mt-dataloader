{
  "connections": [
    {
      "ref": "demo_bank",
      "entity_id": "example1",
      "nickname": "PSP sandbox bank"
    }
  ],
  "internal_accounts": [
    {
      "ref": "wallet_a",
      "connection_id": "$ref:connection.demo_bank",
      "name": "Wallet A",
      "party_name": "Party A",
      "currency": "USD"
    },
    {
      "ref": "wallet_b",
      "connection_id": "$ref:connection.demo_bank",
      "name": "Wallet B",
      "party_name": "Party B",
      "currency": "USD"
    }
  ],
  "funds_flows": [
    {
      "ref": "internal_transfer",
      "pattern_type": "book_transfer",
      "trace_key": "transfer_id",
      "trace_value_template": "xfer-{ref}-{instance}",
      "actors": {
        "direct_1": {
          "alias": "Source",
          "frame_type": "direct",
          "customer_name": "Party A",
          "slots": {
            "wallet": "$ref:internal_account.wallet_a"
          }
        },
        "direct_2": {
          "alias": "Dest",
          "frame_type": "direct",
          "customer_name": "Party B",
          "slots": {
            "wallet": "$ref:internal_account.wallet_b"
          }
        }
      },
      "steps": [
        {
          "step_id": "book_move",
          "type": "payment_order",
          "payment_type": "book",
          "direction": "credit",
          "amount": 10000,
          "originating_account_id": "@actor:direct_1.wallet",
          "receiving_account_id": "@actor:direct_2.wallet",
          "description": "Minimal PSP internal transfer"
        }
      ]
    }
  ]
}
