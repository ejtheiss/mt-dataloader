{
  "connections": [
    {
      "ref": "fiat_bank",
      "entity_id": "example1",
      "nickname": "Fiat Banking Partner (USD)"
    },
    {
      "ref": "stablecoin_rail",
      "entity_id": "example1",
      "nickname": "Stablecoin Rail (USDC)"
    }
  ],
  "ledgers": [
    {
      "ref": "ramp_ledger",
      "name": "Stablecoin Ramp Ledger",
      "description": "Tracks fiat reserves, USDC pool balances, and per-customer positions"
    }
  ],
  "ledger_accounts": [
    {
      "ref": "fiat_reserve",
      "name": "Fiat Reserve (USD)",
      "ledger_id": "$ref:ledger.ramp_ledger",
      "normal_balance": "debit",
      "currency": "USD"
    },
    {
      "ref": "usdc_pool",
      "name": "USDC Pool",
      "ledger_id": "$ref:ledger.ramp_ledger",
      "normal_balance": "debit",
      "currency": "USDC"
    },
    {
      "ref": "conversion_revenue",
      "name": "Conversion Revenue",
      "ledger_id": "$ref:ledger.ramp_ledger",
      "normal_balance": "credit",
      "currency": "USD"
    }
  ],
  "ledger_account_categories": [
    {
      "ref": "customer_usd_balances",
      "name": "Customer USD Balances",
      "ledger_id": "$ref:ledger.ramp_ledger",
      "normal_balance": "credit",
      "currency": "USD"
    },
    {
      "ref": "customer_usdc_balances",
      "name": "Customer USDC Balances",
      "ledger_id": "$ref:ledger.ramp_ledger",
      "normal_balance": "credit",
      "currency": "USDC"
    }
  ],
  "legal_entities": [
    {
      "ref": "platform_entity",
      "legal_entity_type": "business",
      "business_name": "Archer Payments Inc."
    }
  ],
  "internal_accounts": [
    {
      "ref": "c2_payment_usd",
      "connection_id": "$ref:connection.fiat_bank",
      "legal_entity_id": "$ref:legal_entity.platform_entity",
      "name": "C2 Payment Account (USD)",
      "party_name": "Archer Payments Inc.",
      "currency": "USD",
      "metadata": { "account_role": "fiat_collection" }
    },
    {
      "ref": "payment_usdc",
      "connection_id": "$ref:connection.stablecoin_rail",
      "legal_entity_id": "$ref:legal_entity.platform_entity",
      "name": "Payment Account (USDC)",
      "party_name": "Archer Payments Inc.",
      "currency": "USDC",
      "metadata": { "account_role": "usdc_omnibus" }
    },
    {
      "ref": "employee_payment_usd",
      "connection_id": "$ref:connection.fiat_bank",
      "legal_entity_id": "$ref:legal_entity.platform_entity",
      "name": "Employee Payment Account (USD)",
      "party_name": "Archer Payments Inc.",
      "currency": "USD",
      "metadata": { "account_role": "fiat_disbursement" }
    }
  ],
  "funds_flows": [
    {
      "ref": "usdc_onramp",
      "pattern_type": "fiat_to_stablecoin",
      "trace_key": "onramp_id",
      "trace_value_template": "ONRAMP-{instance}",
      "actors": {
        "user_1": {
          "alias": "Customer",
          "frame_type": "user",
          "entity_ref": "$ref:legal_entity.customer_{instance}",
          "slots": {
            "bank": "$ref:counterparty.customer_{instance}_bank.account[0]",
            "wallet": "$ref:counterparty.customer_{instance}_wallet.account[0]",
            "usd_la": "$ref:ledger_account.customer_{instance}_usd",
            "usdc_la": "$ref:ledger_account.customer_{instance}_usdc"
          }
        },
        "direct_1": {
          "alias": "Platform",
          "frame_type": "direct",
          "customer_name": "C2 Inc",
          "slots": {
            "c2_usd": "$ref:internal_account.c2_payment_usd",
            "usdc_account": "$ref:internal_account.payment_usdc",
            "fiat_reserve": "$ref:ledger_account.fiat_reserve",
            "usdc_pool": "$ref:ledger_account.usdc_pool",
            "revenue": "$ref:ledger_account.conversion_revenue"
          }
        }
      },
      "instance_resources": {
        "legal_entities": [
          {
            "ref": "customer_{instance}",
            "legal_entity_type": "individual",
            "first_name": "{first_name}",
            "last_name": "{last_name}"
          }
        ],
        "counterparties": [
          {
            "ref": "customer_{instance}_bank",
            "name": "{first_name} {last_name} Bank Account",
            "legal_entity_id": "$ref:legal_entity.customer_{instance}",
            "accounts": [
              {
                "party_name": "{first_name} {last_name}",
                "party_type": "individual",
                "account_type": "checking",
                "sandbox_behavior": "success",
                "metadata": { "account_label": "fiat_source" }
              }
            ]
          },
          {
            "ref": "customer_{instance}_wallet",
            "name": "{first_name} {last_name} External Wallet",
            "legal_entity_id": "$ref:legal_entity.customer_{instance}",
            "accounts": [
              {
                "party_name": "{first_name} {last_name} USDC Wallet",
                "party_type": "individual",
                "account_type": "other",
                "sandbox_behavior": "success",
                "metadata": { "account_label": "usdc_external_wallet" }
              }
            ]
          }
        ],
        "ledger_accounts": [
          {
            "ref": "customer_{instance}_usd",
            "name": "{first_name} {last_name} USD Position",
            "ledger_id": "$ref:ledger.ramp_ledger",
            "normal_balance": "credit",
            "currency": "USD"
          },
          {
            "ref": "customer_{instance}_usdc",
            "name": "{first_name} {last_name} USDC Position",
            "ledger_id": "$ref:ledger.ramp_ledger",
            "normal_balance": "credit",
            "currency": "USDC"
          }
        ],
        "category_memberships": [
          {
            "ref": "customer_{instance}_usd_in_cat",
            "category_id": "$ref:ledger_account_category.customer_usd_balances",
            "ledger_account_id": "$ref:ledger_account.customer_{instance}_usd"
          },
          {
            "ref": "customer_{instance}_usdc_in_cat",
            "category_id": "$ref:ledger_account_category.customer_usdc_balances",
            "ledger_account_id": "$ref:ledger_account.customer_{instance}_usdc"
          }
        ]
      },
      "steps": [
        {
          "step_id": "ach_deposit",
          "type": "incoming_payment_detail",
          "payment_type": "ach",
          "direction": "credit",
          "amount": 100000,
          "originating_account_id": "@actor:user_1.bank",
          "internal_account_id": "@actor:direct_1.c2_usd",
          "description": "{first_name} {last_name} ACH deposit for USDC purchase"
        },
        {
          "step_id": "lt_record_usd",
          "type": "ledger_transaction",
          "depends_on": ["ach_deposit"],
          "description": "Record USD received from {first_name} {last_name}",
          "ledger_entries": [
            { "amount": 100000, "direction": "debit", "ledger_account_id": "@actor:direct_1.fiat_reserve" },
            { "amount": 100000, "direction": "credit", "ledger_account_id": "@actor:user_1.usd_la" }
          ]
        },
        {
          "step_id": "book_usd_to_usdc",
          "type": "payment_order",
          "payment_type": "book",
          "direction": "credit",
          "amount": 100000,
          "originating_account_id": "@actor:direct_1.c2_usd",
          "receiving_account_id": "@actor:direct_1.usdc_account",
          "depends_on": ["lt_record_usd"],
          "description": "Book transfer USD → USDC omnibus for conversion",
          "ledger_inline": true,
          "ledger_entries": [
            { "amount": 100000, "direction": "debit", "ledger_account_id": "@actor:user_1.usd_la" },
            { "amount": 99500, "direction": "credit", "ledger_account_id": "@actor:user_1.usdc_la" },
            { "amount": 500, "direction": "credit", "ledger_account_id": "@actor:direct_1.revenue" }
          ]
        },
        {
          "step_id": "send_usdc",
          "type": "payment_order",
          "payment_type": "ach",
          "direction": "credit",
          "amount": 99500,
          "originating_account_id": "@actor:direct_1.usdc_account",
          "receiving_account_id": "@actor:user_1.wallet",
          "depends_on": ["book_usd_to_usdc"],
          "description": "Send USDC to {first_name} {last_name} external wallet",
          "ledger_inline": true,
          "ledger_entries": [
            { "amount": 99500, "direction": "debit", "ledger_account_id": "@actor:user_1.usdc_la" },
            { "amount": 99500, "direction": "credit", "ledger_account_id": "@actor:direct_1.usdc_pool" }
          ]
        }
      ],
      "optional_groups": [
        {
          "label": "ACH return (R01 insufficient funds)",
          "trigger": "system",
          "steps": [
            {
              "step_id": "ach_return_nsf",
              "type": "payment_order",
              "payment_type": "ach",
              "direction": "debit",
              "amount": 100000,
              "originating_account_id": "@actor:direct_1.c2_usd",
              "receiving_account_id": "@actor:user_1.bank",
              "depends_on": ["ach_deposit"],
              "description": "ACH return — insufficient funds on customer deposit"
            }
          ]
        }
      ]
    },
    {
      "ref": "usdc_offramp",
      "pattern_type": "stablecoin_to_fiat",
      "trace_key": "offramp_id",
      "trace_value_template": "OFFRAMP-{instance}",
      "actors": {
        "user_1": {
          "alias": "Customer",
          "frame_type": "user",
          "entity_ref": "$ref:legal_entity.customer_{instance}",
          "slots": {
            "bank": "$ref:counterparty.customer_{instance}_bank.account[0]",
            "wallet": "$ref:counterparty.customer_{instance}_wallet.account[0]",
            "usd_la": "$ref:ledger_account.customer_{instance}_usd",
            "usdc_la": "$ref:ledger_account.customer_{instance}_usdc"
          }
        },
        "direct_1": {
          "alias": "Platform",
          "frame_type": "direct",
          "customer_name": "C2 Inc",
          "slots": {
            "usdc_account": "$ref:internal_account.payment_usdc",
            "payout_usd": "$ref:internal_account.employee_payment_usd",
            "fiat_reserve": "$ref:ledger_account.fiat_reserve",
            "usdc_pool": "$ref:ledger_account.usdc_pool",
            "revenue": "$ref:ledger_account.conversion_revenue"
          }
        }
      },
      "steps": [
        {
          "step_id": "usdc_received",
          "type": "incoming_payment_detail",
          "payment_type": "ach",
          "direction": "credit",
          "amount": 75000,
          "originating_account_id": "@actor:user_1.wallet",
          "internal_account_id": "@actor:direct_1.usdc_account",
          "description": "{first_name} {last_name} sends USDC for off-ramp"
        },
        {
          "step_id": "lt_record_usdc",
          "type": "ledger_transaction",
          "depends_on": ["usdc_received"],
          "description": "Record USDC received from {first_name} {last_name}",
          "ledger_entries": [
            { "amount": 75000, "direction": "debit", "ledger_account_id": "@actor:direct_1.usdc_pool" },
            { "amount": 75000, "direction": "credit", "ledger_account_id": "@actor:user_1.usdc_la" }
          ]
        },
        {
          "step_id": "book_usdc_to_usd",
          "type": "payment_order",
          "payment_type": "book",
          "direction": "credit",
          "amount": 75000,
          "originating_account_id": "@actor:direct_1.usdc_account",
          "receiving_account_id": "@actor:direct_1.payout_usd",
          "depends_on": ["lt_record_usdc"],
          "description": "Book transfer USDC → USD for fiat off-ramp",
          "ledger_inline": true,
          "ledger_entries": [
            { "amount": 75000, "direction": "debit", "ledger_account_id": "@actor:user_1.usdc_la" },
            { "amount": 74625, "direction": "credit", "ledger_account_id": "@actor:user_1.usd_la" },
            { "amount": 375, "direction": "credit", "ledger_account_id": "@actor:direct_1.revenue" }
          ]
        },
        {
          "step_id": "fiat_payout",
          "type": "payment_order",
          "payment_type": "ach",
          "direction": "credit",
          "amount": 74625,
          "originating_account_id": "@actor:direct_1.payout_usd",
          "receiving_account_id": "@actor:user_1.bank",
          "depends_on": ["book_usdc_to_usd"],
          "description": "ACH payout of USD to {first_name} {last_name} bank",
          "ledger_inline": true,
          "ledger_entries": [
            { "amount": 74625, "direction": "debit", "ledger_account_id": "@actor:user_1.usd_la" },
            { "amount": 74625, "direction": "credit", "ledger_account_id": "@actor:direct_1.fiat_reserve" }
          ]
        }
      ],
      "optional_groups": [
        {
          "label": "RTP instant payout",
          "trigger": "manual",
          "exclusion_group": "payout_method",
          "position": "replace",
          "insert_after": "fiat_payout",
          "steps": [
            {
              "step_id": "rtp_payout",
              "type": "payment_order",
              "payment_type": "rtp",
              "direction": "credit",
              "amount": 74625,
              "originating_account_id": "@actor:direct_1.payout_usd",
              "receiving_account_id": "@actor:user_1.bank",
              "depends_on": ["book_usdc_to_usd"],
              "description": "RTP instant payout to {first_name} {last_name}",
              "ledger_inline": true,
              "ledger_entries": [
                { "amount": 74625, "direction": "debit", "ledger_account_id": "@actor:user_1.usd_la" },
                { "amount": 74625, "direction": "credit", "ledger_account_id": "@actor:direct_1.fiat_reserve" }
              ]
            }
          ]
        },
        {
          "label": "Wire payout",
          "trigger": "manual",
          "exclusion_group": "payout_method",
          "position": "replace",
          "insert_after": "fiat_payout",
          "steps": [
            {
              "step_id": "wire_payout",
              "type": "payment_order",
              "payment_type": "wire",
              "direction": "credit",
              "amount": 74625,
              "originating_account_id": "@actor:direct_1.payout_usd",
              "receiving_account_id": "@actor:user_1.bank",
              "depends_on": ["book_usdc_to_usd"],
              "description": "Wire payout to {first_name} {last_name}",
              "ledger_inline": true,
              "ledger_entries": [
                { "amount": 74625, "direction": "debit", "ledger_account_id": "@actor:user_1.usd_la" },
                { "amount": 74625, "direction": "credit", "ledger_account_id": "@actor:direct_1.fiat_reserve" }
              ]
            }
          ]
        }
      ]
    }
  ]
}
