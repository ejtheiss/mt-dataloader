{
  "connections": [
    {
      "ref": "modern_treasury_bank",
      "entity_id": "example1",
      "nickname": "Modern Treasury PSP"
    }
  ],
  "legal_entities": [
    {
      "ref": "platform_corp",
      "legal_entity_type": "business",
      "business_name": "Boats Group, Inc.",
      "legal_structure": "corporation",
      "metadata": { "user_type": "platform" }
    }
  ],
  "internal_accounts": [
    {
      "ref": "platform_revenue",
      "connection_id": "$ref:connection.modern_treasury_bank",
      "legal_entity_id": "$ref:legal_entity.platform_corp",
      "name": "Boats Group Revenue Account",
      "party_name": "Boats Group, Inc.",
      "currency": "USD",
      "metadata": { "account_purpose": "platform_revenue" }
    }
  ],
  "funds_flows": [
    {
      "ref": "marketplace_purchase",
      "pattern_type": "marketplace_settlement",
      "trace_key": "listing_id",
      "trace_value_template": "BOAT-{ref}-{instance}",
      "actors": {
        "user_1": {
          "alias": "Buyer",
          "frame_type": "user",
          "entity_ref": "$ref:legal_entity.buyer_{instance}",
          "slots": {
            "bank": "$ref:counterparty.buyer_{instance}_cp.account[0]",
            "wallet": "$ref:internal_account.buyer_{instance}_wallet"
          }
        },
        "user_2": {
          "alias": "Seller",
          "frame_type": "user",
          "entity_ref": "$ref:legal_entity.seller_{instance}",
          "slots": {
            "wallet": "$ref:internal_account.seller_{instance}_wallet",
            "bank": "$ref:counterparty.seller_{instance}_cp.account[0]"
          }
        },
        "direct_1": {
          "alias": "Platform",
          "frame_type": "direct",
          "customer_name": "Platform",
          "slots": {
            "revenue": "$ref:internal_account.platform_revenue"
          }
        }
      },
      "instance_resources": {
        "legal_entities": [
          {
            "ref": "buyer_{instance}",
            "legal_entity_type": "individual",
            "first_name": "{first_name}",
            "last_name": "{last_name}",
            "metadata": { "user_type": "buyer" }
          },
          {
            "ref": "seller_{instance}",
            "legal_entity_type": "business",
            "business_name": "{business_name}",
            "metadata": { "user_type": "seller" }
          }
        ],
        "counterparties": [
          {
            "ref": "buyer_{instance}_cp",
            "name": "{first_name} {last_name}",
            "legal_entity_id": "$ref:legal_entity.buyer_{instance}",
            "accounts": [
              {
                "party_name": "{first_name} {last_name}",
                "party_type": "individual",
                "account_type": "checking",
                "sandbox_behavior": "success",
                "metadata": { "account_purpose": "buyer_funding" }
              }
            ]
          },
          {
            "ref": "seller_{instance}_cp",
            "name": "{business_name}",
            "legal_entity_id": "$ref:legal_entity.seller_{instance}",
            "accounts": [
              {
                "party_name": "{business_name}",
                "party_type": "business",
                "account_type": "checking",
                "sandbox_behavior": "success",
                "metadata": { "account_purpose": "seller_payout" }
              }
            ]
          }
        ],
        "internal_accounts": [
          {
            "ref": "buyer_{instance}_wallet",
            "connection_id": "$ref:connection.modern_treasury_bank",
            "legal_entity_id": "$ref:legal_entity.buyer_{instance}",
            "name": "{first_name} {last_name} Buyer Wallet",
            "party_name": "{first_name} {last_name}",
            "currency": "USD",
            "metadata": { "account_purpose": "buyer_sub_account" }
          },
          {
            "ref": "seller_{instance}_wallet",
            "connection_id": "$ref:connection.modern_treasury_bank",
            "legal_entity_id": "$ref:legal_entity.seller_{instance}",
            "name": "{business_name} Seller Wallet",
            "party_name": "{business_name}",
            "currency": "USD",
            "metadata": { "account_purpose": "seller_sub_account" }
          }
        ]
      },
      "steps": [
        {
          "step_id": "buyer_deposit",
          "type": "incoming_payment_detail",
          "payment_type": "ach",
          "direction": "credit",
          "amount": 13750000,
          "originating_account_id": "@actor:user_1.bank",
          "internal_account_id": "@actor:user_1.wallet",
          "description": "Buyer incoming ACH deposit for purchase"
        },
        {
          "step_id": "platform_fee",
          "type": "payment_order",
          "payment_type": "book",
          "direction": "credit",
          "amount": 412500,
          "originating_account_id": "@actor:user_1.wallet",
          "receiving_account_id": "@actor:direct_1.revenue",
          "depends_on": ["buyer_deposit"],
          "description": "Marketplace commission (3%)",
          "metadata": { "fee_type": "marketplace_commission", "fee_rate_pct": "3.0" }
        },
        {
          "step_id": "settle_seller",
          "type": "payment_order",
          "payment_type": "book",
          "direction": "credit",
          "amount": 13337500,
          "originating_account_id": "@actor:user_1.wallet",
          "receiving_account_id": "@actor:user_2.wallet",
          "depends_on": ["platform_fee"],
          "description": "Net proceeds to seller wallet"
        },
        {
          "step_id": "payout_seller",
          "type": "payment_order",
          "payment_type": "ach",
          "direction": "credit",
          "amount": 13337500,
          "originating_account_id": "@actor:user_2.wallet",
          "receiving_account_id": "@actor:user_2.bank",
          "depends_on": ["settle_seller"],
          "description": "ACH payout to seller bank account"
        }
      ],
      "optional_groups": [
        {
          "label": "ACH return (NSF)",
          "trigger": "system",
          "steps": [
            {
              "step_id": "nsf_return",
              "type": "return",
              "depends_on": ["buyer_deposit"],
              "code": "R01",
              "description": "Buyer ACH deposit returned — insufficient funds"
            }
          ]
        }
      ]
    }
  ]
}
