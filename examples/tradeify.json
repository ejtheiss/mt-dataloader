{
  "connections": [
    {
      "ref": "tradeify_psp_usd",
      "entity_id": "example1",
      "nickname": "Modern Treasury PSP USD"
    },
    {
      "ref": "tradeify_psp_usdg",
      "entity_id": "example1",
      "nickname": "Modern Treasury PSP USDG"
    }
  ],
  "ledgers": [
    {
      "ref": "tradeify_wallet_ledger",
      "name": "Tradeify Wallet Ledger",
      "description": "Tradeify rewards wallet ledger with pooled USDG liquidity and per-user USD/USDG balances"
    }
  ],
  "ledger_accounts": [
    {
      "ref": "platform_rewards_expense",
      "name": "Platform Rewards Expense",
      "ledger_id": "$ref:ledger.tradeify_wallet_ledger",
      "normal_balance": "debit",
      "currency": "USD"
    },
    {
      "ref": "platform_usd_reserve",
      "name": "Platform USD Reserve",
      "ledger_id": "$ref:ledger.tradeify_wallet_ledger",
      "normal_balance": "debit",
      "currency": "USD"
    },
    {
      "ref": "platform_usdg_pool",
      "name": "Platform USDG Pool",
      "ledger_id": "$ref:ledger.tradeify_wallet_ledger",
      "normal_balance": "debit",
      "currency": "USDG"
    }
  ],
  "ledger_account_categories": [
    {
      "ref": "user_wallets_usd",
      "name": "User Wallets USD",
      "ledger_id": "$ref:ledger.tradeify_wallet_ledger",
      "normal_balance": "credit",
      "currency": "USD"
    },
    {
      "ref": "user_wallets_usdg",
      "name": "User Wallets USDG",
      "ledger_id": "$ref:ledger.tradeify_wallet_ledger",
      "normal_balance": "credit",
      "currency": "USDG"
    },
    {
      "ref": "platform_balances_usd",
      "name": "Platform Balances USD",
      "ledger_id": "$ref:ledger.tradeify_wallet_ledger",
      "normal_balance": "debit",
      "currency": "USD"
    },
    {
      "ref": "platform_balances_usdg",
      "name": "Platform Balances USDG",
      "ledger_id": "$ref:ledger.tradeify_wallet_ledger",
      "normal_balance": "debit",
      "currency": "USDG"
    }
  ],
  "legal_entities": [
    {
      "ref": "tradeify_holdings",
      "legal_entity_type": "business",
      "business_name": "Tradeify Holdings"
    },
    {
      "ref": "ninjatrader_group",
      "legal_entity_type": "business",
      "business_name": "NinjaTrader Group"
    }
  ],
  "counterparties": [
    {
      "ref": "ninjatrader_bmo_cp",
      "name": "NinjaTrader BMO",
      "legal_entity_id": "$ref:legal_entity.ninjatrader_group",
      "metadata": { "partner_name": "ninjatrader", "partner_type": "brokerage" }
    }
  ],
  "external_accounts": [
    {
      "ref": "ninjatrader_bmo_funding",
      "counterparty_id": "$ref:counterparty.ninjatrader_bmo_cp",
      "party_name": "NinjaTrader BMO Funding",
      "party_type": "business",
      "account_type": "checking",
      "account_details": [{ "account_number": "123456789" }],
      "routing_details": [{ "routing_number": "121141822", "routing_number_type": "aba" }],
      "metadata": { "account_label": "ninjatrader_bmo_funding" }
    },
    {
      "ref": "ninjatrader_bmo_return",
      "counterparty_id": "$ref:counterparty.ninjatrader_bmo_cp",
      "party_name": "NinjaTrader BMO Return Source",
      "party_type": "business",
      "account_type": "checking",
      "account_details": [{ "account_number": "123456789" }],
      "routing_details": [{ "routing_number": "121141822", "routing_number_type": "aba" }],
      "metadata": { "account_label": "ninjatrader_bmo_return_source" }
    }
  ],
  "internal_accounts": [
    {
      "ref": "tradeify_c_payment",
      "connection_id": "$ref:connection.tradeify_psp_usd",
      "legal_entity_id": "$ref:legal_entity.tradeify_holdings",
      "name": "Tradeify C! Payment Account",
      "party_name": "Tradeify Holdings",
      "currency": "USD",
      "metadata": { "account_role": "reward_funding_source" }
    },
    {
      "ref": "tradeify_usd_treasury",
      "connection_id": "$ref:connection.tradeify_psp_usd",
      "legal_entity_id": "$ref:legal_entity.tradeify_holdings",
      "name": "Tradeify USD Treasury Account",
      "party_name": "Tradeify Holdings",
      "currency": "USD",
      "metadata": { "account_role": "usd_treasury" }
    },
    {
      "ref": "tradeify_usdg_pool",
      "connection_id": "$ref:connection.tradeify_psp_usdg",
      "legal_entity_id": "$ref:legal_entity.tradeify_holdings",
      "name": "Tradeify USDG Payment Account",
      "party_name": "Tradeify Holdings",
      "currency": "USDG",
      "metadata": { "account_role": "usdg_pool" }
    }
  ],
  "category_memberships": [
    {
      "ref": "platform_usd_reserve_in_platform",
      "category_id": "$ref:ledger_account_category.platform_balances_usd",
      "ledger_account_id": "$ref:ledger_account.platform_usd_reserve"
    },
    {
      "ref": "platform_usdg_pool_in_platform",
      "category_id": "$ref:ledger_account_category.platform_balances_usdg",
      "ledger_account_id": "$ref:ledger_account.platform_usdg_pool"
    },
    {
      "ref": "platform_rewards_expense_in_platform",
      "category_id": "$ref:ledger_account_category.platform_balances_usd",
      "ledger_account_id": "$ref:ledger_account.platform_rewards_expense"
    }
  ],
  "funds_flows": [
    {
      "ref": "user_lifecycle",
      "pattern_type": "rewards_wallet",
      "trace_key": "user_id",
      "trace_value_template": "USR-{instance}",
      "actors": {
        "user_1": {
          "alias": "User",
          "frame_type": "user",
          "entity_ref": "$ref:legal_entity.user_{instance}",
          "slots": {
            "wallet": "$ref:internal_account.user_{instance}_usd_wallet",
            "usd_la": "$ref:ledger_account.user_{instance}_usd_balance",
            "usdg_la": "$ref:ledger_account.user_{instance}_usdg_balance",
            "bank": "$ref:counterparty.user_{instance}_bank_cp.account[0]"
          }
        },
        "direct_1": {
          "alias": "Platform",
          "frame_type": "direct",
          "customer_name": "Tradeify",
          "slots": {
            "c_payment": "$ref:internal_account.tradeify_c_payment",
            "usdg_pool_ia": "$ref:internal_account.tradeify_usdg_pool",
            "rewards_expense": "$ref:ledger_account.platform_rewards_expense",
            "usd_reserve": "$ref:ledger_account.platform_usd_reserve",
            "usdg_pool_la": "$ref:ledger_account.platform_usdg_pool"
          }
        },
        "direct_2": {
          "alias": "NinjaTrader",
          "frame_type": "direct",
          "entity_ref": "$ref:legal_entity.ninjatrader_group",
          "customer_name": "NinjaTrader Group",
          "slots": {
            "cp": "$ref:counterparty.ninjatrader_bmo_cp",
            "funding": "$ref:external_account.ninjatrader_bmo_funding",
            "return": "$ref:external_account.ninjatrader_bmo_return"
          }
        }
      },
      "instance_resources": {
        "legal_entities": [
          {
            "ref": "user_{instance}",
            "legal_entity_type": "individual",
            "first_name": "{first_name}",
            "last_name": "{last_name}"
          }
        ],
        "counterparties": [
          {
            "ref": "user_{instance}_bank_cp",
            "name": "{first_name} {last_name} External Bank",
            "legal_entity_id": "$ref:legal_entity.user_{instance}",
            "accounts": [
              {
                "party_name": "{first_name} {last_name}",
                "party_type": "individual",
                "account_type": "checking",
                "sandbox_behavior": "success",
                "metadata": { "account_label": "primary_cashout_bank" }
              }
            ],
            "metadata": { "counterparty_role": "cashout_destination" }
          }
        ],
        "internal_accounts": [
          {
            "ref": "user_{instance}_usd_wallet",
            "connection_id": "$ref:connection.tradeify_psp_usd",
            "legal_entity_id": "$ref:legal_entity.user_{instance}",
            "name": "{first_name} {last_name} USD Wallet",
            "party_name": "{first_name} {last_name}",
            "currency": "USD",
            "metadata": { "wallet_currency": "USD" }
          }
        ],
        "ledger_accounts": [
          {
            "ref": "user_{instance}_usd_balance",
            "name": "{first_name} {last_name} USD Balance",
            "ledger_id": "$ref:ledger.tradeify_wallet_ledger",
            "normal_balance": "credit",
            "currency": "USD"
          },
          {
            "ref": "user_{instance}_usdg_balance",
            "name": "{first_name} {last_name} USDG Balance",
            "ledger_id": "$ref:ledger.tradeify_wallet_ledger",
            "normal_balance": "credit",
            "currency": "USDG"
          }
        ],
        "category_memberships": [
          {
            "ref": "user_{instance}_usd_in_wallets",
            "category_id": "$ref:ledger_account_category.user_wallets_usd",
            "ledger_account_id": "$ref:ledger_account.user_{instance}_usd_balance"
          },
          {
            "ref": "user_{instance}_usdg_in_wallets",
            "category_id": "$ref:ledger_account_category.user_wallets_usdg",
            "ledger_account_id": "$ref:ledger_account.user_{instance}_usdg_balance"
          }
        ]
      },
      "steps": [
        {
          "step_id": "ipd_onramp",
          "type": "incoming_payment_detail",
          "payment_type": "ach",
          "direction": "credit",
          "amount": 50000,
          "originating_account_id": "@actor:user_1.bank",
          "internal_account_id": "@actor:user_1.wallet",
          "description": "{first_name} {last_name} on-ramps USD via ACH deposit"
        },
        {
          "step_id": "lt_seed_balance",
          "type": "ledger_transaction",
          "depends_on": ["ipd_onramp"],
          "description": "Seed {first_name} {last_name} USD ledger balance from reward",
          "ledger_entries": [
            { "amount": 120000, "direction": "debit", "ledger_account_id": "@actor:direct_1.rewards_expense" },
            { "amount": 120000, "direction": "credit", "ledger_account_id": "@actor:user_1.usd_la" }
          ]
        },
        {
          "step_id": "po_reward_fund",
          "type": "payment_order",
          "payment_type": "book",
          "direction": "credit",
          "amount": 120000,
          "originating_account_id": "@actor:direct_1.c_payment",
          "receiving_account_id": "@actor:user_1.wallet",
          "depends_on": ["lt_seed_balance"],
          "description": "Tradeify reward funding to {first_name} {last_name} USD wallet"
        },
        {
          "step_id": "lt_usd_to_usdg",
          "type": "ledger_transaction",
          "depends_on": ["po_reward_fund"],
          "description": "Convert {first_name} {last_name} USD wallet balance to USDG",
          "ledger_entries": [
            { "amount": 120000, "direction": "credit", "ledger_account_id": "@actor:direct_1.usd_reserve" },
            { "amount": 120000, "direction": "debit", "ledger_account_id": "@actor:direct_1.usdg_pool_la" },
            { "amount": 120000, "direction": "debit", "ledger_account_id": "@actor:user_1.usd_la" },
            { "amount": 120000, "direction": "credit", "ledger_account_id": "@actor:user_1.usdg_la" }
          ]
        }
      ],
      "optional_groups": [
        {
          "label": "ACH cashout",
          "trigger": "manual",
          "steps": [
            {
              "step_id": "lt_usdg_to_usd_cashout",
              "type": "ledger_transaction",
              "depends_on": ["lt_usd_to_usdg"],
              "description": "Off-ramp USDG balance to USD for bank cashout",
              "ledger_entries": [
                { "amount": 30000, "direction": "debit", "ledger_account_id": "@actor:direct_1.usd_reserve" },
                { "amount": 30000, "direction": "credit", "ledger_account_id": "@actor:direct_1.usdg_pool_la" },
                { "amount": 30000, "direction": "debit", "ledger_account_id": "@actor:user_1.usdg_la" },
                { "amount": 30000, "direction": "credit", "ledger_account_id": "@actor:user_1.usd_la" }
              ]
            },
            {
              "step_id": "po_cashout",
              "type": "payment_order",
              "payment_type": "ach",
              "direction": "credit",
              "amount": 30000,
              "originating_account_id": "@actor:user_1.wallet",
              "receiving_account_id": "@actor:user_1.bank",
              "depends_on": ["lt_usdg_to_usd_cashout"],
              "description": "{first_name} {last_name} cashout to external bank",
              "ledger_inline": true,
              "ledger_entries": [
                { "amount": 30000, "direction": "debit", "ledger_account_id": "@actor:user_1.usd_la" },
                { "amount": 30000, "direction": "credit", "ledger_account_id": "@actor:direct_1.usd_reserve" }
              ]
            }
          ]
        },
        {
          "label": "NinjaTrader wire funding",
          "trigger": "manual",
          "steps": [
            {
              "step_id": "lt_usdg_to_usd_nt",
              "type": "ledger_transaction",
              "depends_on": ["lt_usd_to_usdg"],
              "description": "Off-ramp USDG to USD for NinjaTrader funding",
              "ledger_entries": [
                { "amount": 25000, "direction": "debit", "ledger_account_id": "@actor:direct_1.usd_reserve" },
                { "amount": 25000, "direction": "credit", "ledger_account_id": "@actor:direct_1.usdg_pool_la" },
                { "amount": 25000, "direction": "debit", "ledger_account_id": "@actor:user_1.usdg_la" },
                { "amount": 25000, "direction": "credit", "ledger_account_id": "@actor:user_1.usd_la" }
              ]
            },
            {
              "step_id": "po_fund_nt",
              "type": "payment_order",
              "payment_type": "wire",
              "direction": "credit",
              "amount": 25000,
              "originating_account_id": "@actor:user_1.wallet",
              "receiving_account_id": "@actor:direct_2.funding",
              "depends_on": ["lt_usdg_to_usd_nt"],
              "description": "{first_name} {last_name} funds NinjaTrader brokerage",
              "ledger_inline": true,
              "ledger_entries": [
                { "amount": 25000, "direction": "debit", "ledger_account_id": "@actor:user_1.usd_la" },
                { "amount": 25000, "direction": "credit", "ledger_account_id": "@actor:direct_1.usd_reserve" }
              ]
            }
          ]
        },
        {
          "label": "Staged NinjaTrader return",
          "trigger": "manual",
          "steps": [
            {
              "step_id": "lt_usdg_to_usd_staged",
              "type": "ledger_transaction",
              "depends_on": ["lt_usd_to_usdg"],
              "description": "Off-ramp USDG to USD for staged NinjaTrader funding",
              "ledger_entries": [
                { "amount": 70000, "direction": "debit", "ledger_account_id": "@actor:direct_1.usd_reserve" },
                { "amount": 70000, "direction": "credit", "ledger_account_id": "@actor:direct_1.usdg_pool_la" },
                { "amount": 70000, "direction": "debit", "ledger_account_id": "@actor:user_1.usdg_la" },
                { "amount": 70000, "direction": "credit", "ledger_account_id": "@actor:user_1.usd_la" }
              ]
            },
            {
              "step_id": "po_fund_nt_staged",
              "type": "payment_order",
              "payment_type": "wire",
              "direction": "credit",
              "amount": 70000,
              "originating_account_id": "@actor:user_1.wallet",
              "receiving_account_id": "@actor:direct_2.funding",
              "depends_on": ["lt_usdg_to_usd_staged"],
              "description": "Staged NinjaTrader funding",
              "staged": true,
              "ledger_inline": true,
              "ledger_entries": [
                { "amount": 70000, "direction": "debit", "ledger_account_id": "@actor:user_1.usd_la" },
                { "amount": 70000, "direction": "credit", "ledger_account_id": "@actor:direct_1.usd_reserve" }
              ]
            },
            {
              "step_id": "po_nt_backflow_staged",
              "type": "payment_order",
              "payment_type": "ach",
              "direction": "debit",
              "amount": 25000,
              "originating_account_id": "@actor:user_1.wallet",
              "receiving_account_id": "@actor:direct_2.return",
              "depends_on": ["po_fund_nt_staged"],
              "description": "Staged NinjaTrader backflow",
              "staged": true,
              "ledger_inline": true,
              "ledger_entries": [
                { "amount": 25000, "direction": "debit", "ledger_account_id": "@actor:direct_1.usd_reserve" },
                { "amount": 25000, "direction": "credit", "ledger_account_id": "@actor:user_1.usd_la" }
              ]
            }
          ]
        }
      ]
    }
  ]
}
