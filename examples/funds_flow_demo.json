{
  "connections": [
    {"ref": "demo_bank", "entity_id": "modern_treasury"}
  ],
  "internal_accounts": [
    {
      "ref": "ops_usd",
      "connection_id": "$ref:connection.demo_bank",
      "name": "Ops USD",
      "party_name": "Demo Corp",
      "currency": "USD"
    }
  ],
  "ledgers": [
    {"ref": "main", "name": "Main Ledger"}
  ],
  "ledger_accounts": [
    {
      "ref": "cash",
      "ledger_id": "$ref:ledger.main",
      "name": "Cash",
      "normal_balance": "debit",
      "currency": "USD"
    },
    {
      "ref": "revenue",
      "ledger_id": "$ref:ledger.main",
      "name": "Revenue",
      "normal_balance": "credit",
      "currency": "USD"
    }
  ],
  "counterparties": [
    {
      "ref": "demo_customer",
      "name": "Demo Customer",
      "accounts": [
        {
          "party_name": "Demo Customer",
          "party_type": "individual",
          "account_type": "checking",
          "sandbox_behavior": "success"
        }
      ]
    }
  ],
  "funds_flows": [
    {
      "ref": "simple_deposit",
      "pattern_type": "deposit_settle",
      "display_title": "Demo deposit & settle",
      "display_summary": "ACH deposit with ledger settlement and optional return path for Fund Flows UI demos.",
      "trace_key": "deal_id",
      "trace_value_template": "deal-{ref}-{instance}",
      "actors": {
        "direct_1": {
          "alias": "Customer",
          "frame_type": "direct",
          "customer_name": "Demo Customer",
          "slots": {
            "bank": "$ref:counterparty.demo_customer.account[0]"
          }
        },
        "direct_2": {
          "alias": "Platform",
          "frame_type": "direct",
          "customer_name": "Demo Corp",
          "slots": {
            "ops": "$ref:internal_account.ops_usd",
            "cash": "$ref:ledger_account.cash",
            "revenue": "$ref:ledger_account.revenue"
          }
        }
      },
      "steps": [
        {
          "step_id": "deposit",
          "type": "incoming_payment_detail",
          "payment_type": "ach",
          "direction": "credit",
          "amount": 50000,
          "originating_account_id": "@actor:direct_1.bank",
          "internal_account_id": "@actor:direct_2.ops",
          "description": "Incoming ACH deposit for {first_name} {last_name}"
        },
        {
          "step_id": "settle",
          "type": "ledger_transaction",
          "depends_on": ["deposit"],
          "description": "Book the settled deposit for {first_name} {last_name}",
          "ledger_status": "pending",
          "ledger_entries": [
            {
              "ledger_account_id": "@actor:direct_2.cash",
              "amount": 50000,
              "direction": "debit"
            },
            {
              "ledger_account_id": "@actor:direct_2.revenue",
              "amount": 50000,
              "direction": "credit"
            }
          ]
        },
        {
          "step_id": "post_settle",
          "type": "transition_ledger_transaction",
          "depends_on": ["settle"],
          "status": "posted",
          "description": "Post the settlement LT after deposit completes"
        }
      ],
      "optional_groups": [
        {
          "label": "Customer requests return",
          "trigger": "manual",
          "steps": [
            {
              "step_id": "return_deposit",
              "type": "return",
              "depends_on": ["deposit"]
            },
            {
              "step_id": "archive_settle",
              "type": "transition_ledger_transaction",
              "depends_on": ["settle"],
              "status": "archived",
              "description": "Archive the original settlement LT"
            },
            {
              "step_id": "reverse_settle",
              "type": "ledger_transaction",
              "depends_on": ["return_deposit"],
              "description": "Reverse the settled deposit",
              "ledger_entries": [
                {
                  "ledger_account_id": "@actor:direct_2.cash",
                  "amount": 50000,
                  "direction": "credit"
                },
                {
                  "ledger_account_id": "@actor:direct_2.revenue",
                  "amount": 50000,
                  "direction": "debit"
                }
              ]
            }
          ]
        }
      ]
    }
  ]
}
