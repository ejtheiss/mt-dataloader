{
  "connections": [
    {
      "ref": "bank",
      "entity_id": "modern_treasury",
      "nickname": "PSP Connection"
    }
  ],
  "legal_entities": [
    {
      "ref": "lendco_inc",
      "legal_entity_type": "business",
      "business_name": "LendCo Inc."
    }
  ],
  "internal_accounts": [
    {
      "ref": "ops",
      "connection_id": "$ref:connection.bank",
      "legal_entity_id": "$ref:legal_entity.lendco_inc",
      "name": "Operating Account",
      "party_name": "LendCo Inc.",
      "currency": "USD"
    },
    {
      "ref": "collections",
      "connection_id": "$ref:connection.bank",
      "legal_entity_id": "$ref:legal_entity.lendco_inc",
      "name": "Collections Account",
      "party_name": "LendCo Inc.",
      "currency": "USD"
    }
  ],
  "ledgers": [
    {
      "ref": "main",
      "name": "LendCo General Ledger"
    }
  ],
  "ledger_accounts": [
    {
      "ref": "cash",
      "ledger_id": "$ref:ledger.main",
      "name": "Cash",
      "normal_balance": "debit",
      "currency": "USD"
    },
    {
      "ref": "interest_income",
      "ledger_id": "$ref:ledger.main",
      "name": "Servicing Income",
      "normal_balance": "credit",
      "currency": "USD"
    },
    {
      "ref": "deposits_payable",
      "ledger_id": "$ref:ledger.main",
      "name": "Investor Funding Payable",
      "normal_balance": "credit",
      "currency": "USD"
    }
  ],
  "funds_flows": [
    {
      "ref": "customer_deposit",
      "pattern_type": "deposit",
      "display_title": "Investor funding deposit",
      "display_summary": "ACH from investor bank to platform ops; books cash vs deposits payable on the main ledger.",
      "trace_key": "deposit_id",
      "trace_value_template": "DEP-{instance}",
      "actors": {
        "user_2": {
          "alias": "Investor",
          "frame_type": "user",
          "entity_ref": "$ref:legal_entity.investor_{instance}",
          "slots": {
            "bank": "$ref:counterparty.investor_{instance}.account[0]"
          }
        },
        "direct_1": {
          "alias": "Platform",
          "frame_type": "direct",
          "customer_name": "LendCo Inc.",
          "slots": {
            "ops": "$ref:internal_account.ops",
            "cash": "$ref:ledger_account.cash",
            "deposits_payable": "$ref:ledger_account.deposits_payable"
          }
        }
      },
      "instance_resources": {
        "legal_entities": [
          {
            "ref": "investor_{instance}",
            "legal_entity_type": "individual",
            "first_name": "{first_name}",
            "last_name": "{last_name}"
          }
        ],
        "counterparties": [
          {
            "ref": "investor_{instance}",
            "name": "{first_name} {last_name}",
            "legal_entity_id": "$ref:legal_entity.investor_{instance}",
            "accounts": [
              {
                "party_name": "{first_name} {last_name}",
                "party_type": "individual",
                "account_type": "savings",
                "sandbox_behavior": "success"
              }
            ]
          }
        ]
      },
      "steps": [
        {
          "step_id": "receive_deposit",
          "type": "incoming_payment_detail",
          "payment_type": "ach",
          "direction": "credit",
          "amount": 5000000,
          "originating_account_id": "@actor:user_2.bank",
          "internal_account_id": "@actor:direct_1.ops",
          "as_of_date": "2025-09-29",
          "description": "Investor ACH funding deposit from {first_name} {last_name}"
        },
        {
          "step_id": "book_deposit",
          "type": "ledger_transaction",
          "depends_on": [
            "receive_deposit"
          ],
          "effective_date": "2025-09-29",
          "description": "Record investor funding liability",
          "ledger_entries": [
            {
              "ledger_account_id": "@actor:direct_1.cash",
              "amount": 5000000,
              "direction": "debit"
            },
            {
              "ledger_account_id": "@actor:direct_1.deposits_payable",
              "amount": 5000000,
              "direction": "credit"
            }
          ]
        }
      ]
    },
    {
      "ref": "loan_disbursement",
      "pattern_type": "disbursement",
      "display_title": "Loan disbursement",
      "display_summary": "Book transfer to beneficiary wallet with loan principal recorded against beneficiary position.",
      "trace_key": "loan_id",
      "trace_value_template": "LOAN-{instance}",
      "actors": {
        "user_1": {
          "alias": "Beneficiary",
          "frame_type": "user",
          "entity_ref": "$ref:legal_entity.beneficiary_{instance}",
          "slots": {
            "external_bank": "$ref:counterparty.beneficiary_external_{instance}.account[0]",
            "wallet": "$ref:internal_account.beneficiary_{instance}_wallet",
            "position": "$ref:ledger_account.beneficiary_{instance}_position"
          }
        },
        "direct_1": {
          "alias": "Platform",
          "frame_type": "direct",
          "customer_name": "LendCo Inc.",
          "slots": {
            "ops": "$ref:internal_account.ops",
            "cash": "$ref:ledger_account.cash",
            "deposits_payable": "$ref:ledger_account.deposits_payable"
          }
        }
      },
      "instance_resources": {
        "legal_entities": [
          {
            "ref": "beneficiary_{instance}",
            "legal_entity_type": "business",
            "business_name": "{business_name}"
          }
        ],
        "counterparties": [
          {
            "ref": "beneficiary_external_{instance}",
            "name": "{business_name} Operating Account",
            "accounts": [
              {
                "party_name": "{business_name}",
                "party_type": "business",
                "account_type": "checking",
                "sandbox_behavior": "success"
              }
            ]
          }
        ],
        "internal_accounts": [
          {
            "ref": "beneficiary_{instance}_wallet",
            "connection_id": "$ref:connection.bank",
            "legal_entity_id": "$ref:legal_entity.beneficiary_{instance}",
            "name": "{business_name} Beneficiary Wallet",
            "party_name": "{business_name}",
            "currency": "USD",
            "metadata": {
              "account_purpose": "beneficiary_sub_account"
            }
          }
        ],
        "ledger_accounts": [
          {
            "ref": "beneficiary_{instance}_position",
            "ledger_id": "$ref:ledger.main",
            "name": "{business_name} Loan Position",
            "normal_balance": "debit",
            "currency": "USD"
          }
        ]
      },
      "steps": [
        {
          "step_id": "disburse",
          "type": "payment_order",
          "payment_type": "book",
          "direction": "credit",
          "amount": 5000000,
          "originating_account_id": "@actor:direct_1.ops",
          "receiving_account_id": "@actor:user_1.wallet",
          "effective_date": "2025-10-03",
          "description": "Loan disbursement to {business_name} beneficiary sub account"
        },
        {
          "step_id": "book_loan_principal",
          "type": "ledger_transaction",
          "depends_on": [
            "disburse"
          ],
          "effective_date": "2025-10-03",
          "description": "Record loan principal disbursed as beneficiary receivable",
          "ledger_entries": [
            {
              "ledger_account_id": "@actor:user_1.position",
              "amount": 5000000,
              "direction": "debit"
            },
            {
              "ledger_account_id": "@actor:direct_1.cash",
              "amount": 5000000,
              "direction": "credit"
            }
          ]
        }
      ],
      "optional_groups": [
        {
          "label": "Disbursement reversal",
          "trigger": "system",
          "steps": [
            {
              "step_id": "reverse_disburse",
              "type": "reversal",
              "depends_on": [
                "disburse"
              ],
              "description": "Reverse failed disbursement"
            }
          ]
        }
      ]
    },
    {
      "ref": "loan_repayment",
      "pattern_type": "repayment",
      "display_title": "Loan repayment & distribution",
      "display_summary": "ACH pull from beneficiary; apply principal, accrue investor payable, recognize servicing, distribute to investor.",
      "trace_key": "repayment_id",
      "trace_value_template": "REPAY-{instance}",
      "actors": {
        "user_1": {
          "alias": "Beneficiary",
          "frame_type": "user",
          "entity_ref": "$ref:legal_entity.beneficiary_{instance}",
          "slots": {
            "external_bank": "$ref:counterparty.beneficiary_external_{instance}.account[0]",
            "wallet": "$ref:internal_account.beneficiary_{instance}_wallet",
            "position": "$ref:ledger_account.beneficiary_{instance}_position"
          }
        },
        "user_2": {
          "alias": "Investor",
          "frame_type": "user",
          "entity_ref": "$ref:legal_entity.investor_{instance}",
          "slots": {
            "bank": "$ref:counterparty.investor_{instance}.account[0]",
            "payable": "$ref:ledger_account.investor_{instance}_payable"
          }
        },
        "direct_1": {
          "alias": "Platform",
          "frame_type": "direct",
          "customer_name": "LendCo Inc.",
          "slots": {
            "collections": "$ref:internal_account.collections",
            "cash": "$ref:ledger_account.cash",
            "interest_income": "$ref:ledger_account.interest_income"
          }
        }
      },
      "instance_resources": {
        "legal_entities": [
          {
            "ref": "beneficiary_{instance}",
            "legal_entity_type": "business",
            "business_name": "{business_name}"
          },
          {
            "ref": "investor_{instance}",
            "legal_entity_type": "individual",
            "first_name": "{first_name}",
            "last_name": "{last_name}"
          }
        ],
        "counterparties": [
          {
            "ref": "beneficiary_external_{instance}",
            "name": "{business_name} Operating Account",
            "accounts": [
              {
                "party_name": "{business_name}",
                "party_type": "business",
                "account_type": "checking",
                "sandbox_behavior": "success"
              }
            ]
          },
          {
            "ref": "investor_{instance}",
            "name": "{first_name} {last_name}",
            "legal_entity_id": "$ref:legal_entity.investor_{instance}",
            "accounts": [
              {
                "party_name": "{first_name} {last_name}",
                "party_type": "individual",
                "account_type": "savings",
                "sandbox_behavior": "success"
              }
            ]
          }
        ],
        "internal_accounts": [
          {
            "ref": "beneficiary_{instance}_wallet",
            "connection_id": "$ref:connection.bank",
            "legal_entity_id": "$ref:legal_entity.beneficiary_{instance}",
            "name": "{business_name} Beneficiary Wallet",
            "party_name": "{business_name}",
            "currency": "USD",
            "metadata": {
              "account_purpose": "beneficiary_sub_account"
            }
          }
        ],
        "ledger_accounts": [
          {
            "ref": "beneficiary_{instance}_position",
            "ledger_id": "$ref:ledger.main",
            "name": "{business_name} Loan Position",
            "normal_balance": "debit",
            "currency": "USD"
          },
          {
            "ref": "investor_{instance}_payable",
            "ledger_id": "$ref:ledger.main",
            "name": "{first_name} {last_name} Investor Distribution Payable",
            "normal_balance": "credit",
            "currency": "USD"
          }
        ]
      },
      "steps": [
        {
          "step_id": "pull_repayment",
          "type": "payment_order",
          "payment_type": "ach",
          "direction": "debit",
          "amount": 525000,
          "originating_account_id": "@actor:direct_1.collections",
          "receiving_account_id": "@actor:user_1.external_bank",
          "effective_date": "2025-11-15",
          "description": "ACH debit repayment pull from {business_name} external account into platform collections"
        },
        {
          "step_id": "apply_principal",
          "type": "ledger_transaction",
          "depends_on": [
            "pull_repayment"
          ],
          "effective_date": "2025-11-18",
          "description": "Apply principal reduction against beneficiary position",
          "ledger_entries": [
            {
              "ledger_account_id": "@actor:direct_1.cash",
              "amount": 500000,
              "direction": "debit"
            },
            {
              "ledger_account_id": "@actor:user_1.position",
              "amount": 500000,
              "direction": "credit"
            }
          ]
        },
        {
          "step_id": "accrue_investor_distribution",
          "type": "ledger_transaction",
          "depends_on": [
            "pull_repayment"
          ],
          "effective_date": "2025-11-18",
          "description": "Accrue investor distribution payable from repayment proceeds",
          "ledger_entries": [
            {
              "ledger_account_id": "@actor:direct_1.cash",
              "amount": 20000,
              "direction": "debit"
            },
            {
              "ledger_account_id": "@actor:user_2.payable",
              "amount": 20000,
              "direction": "credit"
            }
          ]
        },
        {
          "step_id": "recognize_servicing_income",
          "type": "ledger_transaction",
          "depends_on": [
            "pull_repayment"
          ],
          "effective_date": "2025-11-18",
          "description": "Recognize servicing spread retained by platform",
          "ledger_entries": [
            {
              "ledger_account_id": "@actor:direct_1.cash",
              "amount": 5000,
              "direction": "debit"
            },
            {
              "ledger_account_id": "@actor:direct_1.interest_income",
              "amount": 5000,
              "direction": "credit"
            }
          ]
        },
        {
          "step_id": "distribute_to_investor",
          "type": "payment_order",
          "payment_type": "ach",
          "direction": "credit",
          "amount": 20000,
          "originating_account_id": "@actor:direct_1.collections",
          "receiving_account_id": "@actor:user_2.bank",
          "depends_on": [
            "accrue_investor_distribution"
          ],
          "effective_date": "2025-11-24",
          "description": "Weekly investor distribution to {first_name} {last_name} after repayment clearing"
        },
        {
          "step_id": "clear_investor_payable",
          "type": "ledger_transaction",
          "depends_on": [
            "distribute_to_investor"
          ],
          "effective_date": "2025-11-24",
          "description": "Clear investor distribution payable after ACH payout",
          "ledger_entries": [
            {
              "ledger_account_id": "@actor:user_2.payable",
              "amount": 20000,
              "direction": "debit"
            },
            {
              "ledger_account_id": "@actor:direct_1.cash",
              "amount": 20000,
              "direction": "credit"
            }
          ]
        }
      ]
    }
  ]
}
